# ─── API keys ────────────────────────────────────────────
# OpenAI API (for GPT-4o generator)
OPENAI_API_KEY=sk-...

# Anthropic API (for Claude generator)
ANTHROPIC_API_KEY=sk-ant-...

# ─── SSH tunnel to remote GPU server ─────────────────────
# Bastion host (jump server)
SSH_BASTION_HOST=bastion.example.com
SSH_BASTION_PORT=22
SSH_BASTION_USER=ubuntu
SSH_BASTION_KEY=/path/to/your-key.pem

# Target GPU server (reached through bastion)
SSH_TARGET_HOST=10.0.0.1
SSH_TARGET_PORT=22
SSH_TARGET_USER=youruser
SSH_TARGET_PASSWORD=yourpassword
